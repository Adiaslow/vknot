---
/**
 * ResearchHero — the page intro, matching technical's `.intro` idiom
 * (a plain h1 + lead, no kicker or rule). `accent` is accepted for
 * call-site compatibility but no longer rendered.
 */
export interface Props {
  readonly title: string;
  readonly lead: string;
  readonly accent?: string;
}

const { title, lead } = Astro.props;
---

<section class="intro">
  <h1>{title}</h1>
  <p>{lead}</p>
</section>
