---
/**
 * ResearchLayout — the layout for the research subsite.
 *
 * Wraps every page in the shared `<SiteShell>` from @vknot/ui, which
 * provides the design-token CSS, web fonts, the flash-free theme
 * bootstrap, and the colophon footer. This file adds the research-site
 * header (its own nav links). Page content flows into the shell's
 * `<main class="page">` column at the design system's default width.
 */
import { SiteShell, SiteHeader } from "@vknot/ui";

export interface Props {
  readonly title: string;
  readonly description?: string;
}

const { title, description } = Astro.props;
---

<SiteShell {title} description={description ?? "Research portfolio"}>
  <SiteHeader
    slot="header"
    siteName="Adam Murray - Research"
    baseUrl="/adam-murray/research"
    links={[
      { href: "/adam-murray/research", label: "Publications" },
      { href: "/adam-murray/research/labs", label: "Labs" },
      { href: "/adam-murray/research/cv", label: "CV" },
      { href: "https://orcid.org/0009-0006-1673-9485", label: "ORCID" },
    ]}
  />
  <slot />
</SiteShell>
