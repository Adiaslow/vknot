---
/**
 * ArticleHeader — metadata block for a post (and the index cards).
 *
 * The title itself is NOT rendered here. The body `# Title` H1 in each
 * .mdx file is the single source of truth and renders inside the prose
 * content. This component renders the byline, summary, and tag chips
 * that accompany the title.
 *
 * Token-driven; the mono "by-line" and tag style match the identity.
 */
import { ReadingTime } from "./ReadingTime.tsx";

export interface Props {
  readonly summary: string;
  readonly publishDate: string;
  readonly showTags?: boolean;
  readonly tags?: ReadonlyArray<string>;
  readonly readingTimeMinutes?: number;
  /** render as a large standalone header (post page) vs compact (card) */
  readonly variant?: "page" | "card";
}

const {
  summary,
  publishDate,
  showTags = false,
  tags = [],
  readingTimeMinutes,
  variant = "page",
} = Astro.props;

const dateLabel = new Date(publishDate).toLocaleDateString("en-US", {
  year: "numeric", month: "long", day: "numeric",
});
---

<header class:list={["article-header", variant]}>
  <div class="byline">
    <span>Adam Murray</span>
    <span class="sep">/</span>
    <time datetime={publishDate}>{dateLabel}</time>
    {readingTimeMinutes ? (
      <>
        <span class="sep">/</span>
        <ReadingTime minutes={readingTimeMinutes} />
      </>
    ) : null}
  </div>
  <p class="summary">{summary}</p>
  {showTags && tags.length > 0 && (
    <div class="tags">
      {tags.map((tag) => <span class="tag" data-tag={tag}>{tag}</span>)}
    </div>
  )}
</header>

<style>
  .article-header { display: flex; flex-direction: column; gap: 0.9rem; }

  .byline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .byline .sep { color: var(--rule-strong); }

  .summary {
    color: var(--ink-soft);
    max-width: 54ch;
    line-height: 1.5;
  }
  .article-header.page .summary { font-size: 1.18rem; }
  .article-header.card .summary { font-size: 0.95rem; }
  /* .tags / .tag chip styling is shared — see styles/base.css */
</style>
