---
/**
 * BlogLayout — the layout for the technical subsite.
 *
 * Wraps every page (post or index) in the shared `<SiteShell>` from
 * @vknot/ui, which provides the design-token CSS, web fonts, the
 * flash-free theme bootstrap, and the colophon footer. This file
 * adds the technical-site-specific header (its own nav links) and
 * wraps page content in an `<article class="prose">` reading column.
 *
 * The technical site is the canonical example of the shared design
 * system. Other adam-murray subsites use the same SiteShell with
 * their own per-site header content.
 */
import { SiteShell, SiteHeader } from "@vknot/ui";

export interface Props {
  readonly title: string;
  readonly description?: string;
  readonly article?: boolean;
  readonly publishDate?: string;
  readonly tags?: ReadonlyArray<string>;
}

const {
  title,
  description,
  article = false,
  publishDate,
  tags = [],
} = Astro.props;
---

<SiteShell {title} {description} {article} {publishDate} {tags}>
  <SiteHeader
    slot="header"
    siteName="Adam Murray - Research Explorations"
    baseUrl="/adam-murray/technical"
    links={[
      { href: "/adam-murray/technical", label: "Posts" },
      { href: "/adam-murray/technical/about", label: "About" },
    ]}
  />
  <article class="prose">
    <slot />
  </article>
</SiteShell>
