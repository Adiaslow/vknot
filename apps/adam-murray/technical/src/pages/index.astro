---
import { getCollection } from "astro:content";
import BlogLayout from "../layouts/BlogLayout.astro";
import { CategoryTag } from "@vknot/ui";
import CategoryGraph from "../components/interactive/CategoryGraph.tsx";
import {
  buildCategoryGraph,
  settleCategoryGraph,
} from "../lib/category-graph";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((post) => ({
    title: post.data.title,
    summary: post.data.description,
    date: post.data.date,
    tags: post.data.tags,
    href: `/adam-murray/technical/posts/${post.id}`,
    readingTimeMinutes: post.data.readingTimeMinutes,
  }));

const fmtDate = (d: Date) =>
  `${d.getFullYear()}·${String(d.getMonth() + 1).padStart(2, "0")}·${String(d.getDate()).padStart(2, "0")}`;

// Shared-category graph: settled server-side so it renders with JS off and
// never jumps on hydration, then the island keeps it live (see CategoryGraph).
const GRAPH_W = 760;
const GRAPH_H = 420;
const graph = settleCategoryGraph(
  buildCategoryGraph(
    posts.map((p) => ({
      id: p.href,
      title: p.title,
      href: p.href,
      date: p.date,
      tags: p.tags,
    })),
  ),
  { width: GRAPH_W, height: GRAPH_H },
);

// Crop the view tight to the settled nodes (+room for date labels below and
// the hover title above), so the figure has no dead bands around it.
const xs = graph.nodes.map((n) => n.x ?? 0);
const ys = graph.nodes.map((n) => n.y ?? 0);
const PAD_X = 46;
const PAD_TOP = 38;
const PAD_BOTTOM = 42;
const view = {
  x: Math.min(...xs) - PAD_X,
  y: Math.min(...ys) - PAD_TOP,
  w: Math.max(...xs) - Math.min(...xs) + PAD_X * 2,
  h: Math.max(...ys) - Math.min(...ys) + PAD_TOP + PAD_BOTTOM,
};
---

<BlogLayout
  title="Adam Murray — Research Notes"
  description="Computational cyclic peptide researcher exploring geometric deep learning, graph theory, complex systems, and mathematical frameworks."
>
  <CategoryGraph
    client:load
    nodes={graph.nodes}
    links={graph.links}
    width={GRAPH_W}
    height={GRAPH_H}
    view={view}
  />

  <section class="intro">
    <h1>Recent Posts</h1>
    <p>
      Research explorations in computational drug discovery, geometric deep
      learning, and mathematical theory—from rigorous frameworks to playful
      curiosities.
    </p>
  </section>

  <ol class="entry-list">
    {posts.map((post) => (
      <li>
        <a class="entry" href={post.href}>
          <span class="entry-date">{fmtDate(post.date)}</span>
          <span class="entry-body">
            <span class="entry-title">{post.title}</span>
            <span class="entry-summary">{post.summary}</span>
            <span class="tags">
              {post.tags.map((tag) => <CategoryTag id={tag} focusable={false} />)}
            </span>
          </span>
          {post.readingTimeMinutes ? (
            <span class="entry-stat">{post.readingTimeMinutes} min</span>
          ) : <span class="entry-stat" />}
        </a>
      </li>
    ))}
  </ol>
</BlogLayout>
