---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import ArticleMeta from "../../components/ArticleMeta.astro";
import Theorem from "../../components/math/Theorem.astro";
import Definition from "../../components/math/Definition.astro";
import Proof from "../../components/math/Proof.astro";
import Lemma from "../../components/math/Lemma.astro";
import Corollary from "../../components/math/Corollary.astro";
import Remark from "../../components/math/Remark.astro";
import Example from "../../components/math/Example.astro";
import Conjecture from "../../components/math/Conjecture.astro";
import Assumption from "../../components/math/Assumption.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, components: mdxComponents } = await render(post);

// ArticleMeta is exposed to MDX so each post can place
// `<ArticleMeta {...frontmatter} />` right under its `# Title` H1.
// The math environments are exposed the same way.
const components = {
  ...mdxComponents,
  ArticleMeta,
  Theorem,
  Definition,
  Proof,
  Lemma,
  Corollary,
  Remark,
  Example,
  Conjecture,
  Assumption,
};
---

<BlogLayout
  title={post.data.title}
  description={post.data.description ?? ""}
  article={true}
  publishDate={post.data.date.toISOString()}
  tags={post.data.tags}
>
  <Content {components} />
</BlogLayout>
