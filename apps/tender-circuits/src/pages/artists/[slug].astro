---
import LabelLayout from "../../layouts/LabelLayout.astro";
import { artists, type Artist } from "../../data/artists";
import {
  getArtistGenres,
  getVisibleReleasesByArtist,
  getReleaseStatus,
} from "../../data/releases";

export function getStaticPaths() {
  // Generate a page for every artist (including hidden ones, which redirect).
  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist },
  }));
}

interface Props {
  artist: Artist;
}

const { artist } = Astro.props;

// Hidden artist: keep the route in the codebase but redirect away.
if (artist.hidden) {
  return Astro.redirect("/tender_circuits/artists");
}

const genres = getArtistGenres(artist.slug);
const releases = getVisibleReleasesByArtist(artist.slug).map((r) => ({
  title: r.title || r.slug,
  year: r.year,
  catalogNumber: r.catalogNumber,
  slug: r.slug,
  status: getReleaseStatus(r),
}));
const releaseCount = releases.length;
---

<LabelLayout
  title={`${artist.name} - Artist`}
  description={artist.description
    ? `${artist.name}: ${artist.description.substring(0, 150)}...`
    : `${artist.name} on Tender Circuits.`}
>
  <section class="flex flex-col gap-16">
    {/* Artist Header */}
    <div class="card rounded-2xl p-8">
      <div class="flex flex-col gap-6">
        <div class="flex items-center gap-2 text-sm text-slate-400">
          <a
            href="/tender_circuits/artists"
            class="hover:text-slate-300 transition-colors">Artists</a
          >
          <span>/</span>
          <span>{artist.name}</span>
        </div>

        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <h1 class="text-4xl font-bold text-white tracking-tight">
              {artist.name}
            </h1>
            {artist.featured && (
              <span
                class="text-xs uppercase tracking-[0.3em] text-emerald-300 bg-emerald-900/30 px-3 py-1 rounded-full"
              >
                Featured Artist
              </span>
            )}
          </div>

          {(artist.location || releaseCount > 0) && (
            <div class="flex items-center gap-4 text-sm text-slate-400">
              {artist.location && <span>{artist.location}</span>}
              {artist.location && releaseCount > 0 && <span>•</span>}
              {releaseCount > 0 && (
                <span>
                  {releaseCount} release{releaseCount !== 1 ? "s" : ""}
                </span>
              )}
            </div>
          )}
        </div>

        {artist.description && (
          <p class="text-lg text-slate-300 leading-relaxed max-w-4xl">
            {artist.description}
          </p>
        )}

        {genres.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {genres.map((genre) => (
              <span class="text-xs px-3 py-1 rounded-full bg-slate-800 text-slate-300 border border-slate-700">
                {genre}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>

    {/* Approach & Methods */}
    {artist.approach && artist.approach.length > 0 && (
      <section class="card rounded-2xl p-8">
        <div class="flex flex-col gap-6">
          <h2 class="text-2xl font-semibold text-white">Approach & Methods</h2>
          <div class="grid gap-3">
            {artist.approach.map((method) => (
              <div class="flex items-center gap-3">
                <div class="w-1 h-1 rounded-full bg-emerald-400" />
                <span class="text-slate-300">{method}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Releases */}
    {releaseCount > 0 && (
      <section class="flex flex-col gap-12">
        <div class="card rounded-2xl p-6">
          <h2 class="text-2xl font-semibold text-white">
            Releases on Tender Circuits
          </h2>
        </div>

        <div class="flex flex-col gap-6">
          {releases.map((release) => (
            <article class="card group rounded-2xl p-6">
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3">
                  <span class="text-xs uppercase tracking-[0.3em] text-emerald-300 bg-emerald-900/30 px-3 py-1 rounded-full">
                    {release.catalogNumber}
                  </span>
                  {release.year && (
                    <span class="text-xs text-slate-400 font-mono">
                      {release.year}
                    </span>
                  )}
                  {release.status === "comingSoon" && (
                    <span class="text-xs uppercase tracking-[0.3em] text-amber-300 bg-amber-900/30 px-3 py-1 rounded-full">
                      Coming Soon
                    </span>
                  )}
                  {release.status === "preRelease" && (
                    <span class="text-xs uppercase tracking-[0.3em] text-violet-300 bg-violet-900/30 px-3 py-1 rounded-full">
                      Pre-Release
                    </span>
                  )}
                </div>

                <div class="flex flex-col gap-2">
                  <h3 class="text-xl font-bold text-white group-hover:text-emerald-100 transition-colors">
                    {release.title}
                  </h3>
                </div>

                <div class="flex items-center gap-4 pt-2">
                  <a
                    class="inline-flex items-center gap-2 text-sm font-medium text-emerald-300 hover:text-emerald-200 transition-colors"
                    href={`/tender_circuits/releases/${release.slug}`}
                  >
                    <span>{release.status === "published" ? "Listen" : "View"}</span>
                  </a>

                  <a
                    class="inline-flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-300 transition-colors"
                    href="/tender_circuits/releases"
                  >
                    <span>View Discography</span>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {/* Contact/Connect */}
    <section class="card rounded-2xl p-8">
      <div class="flex flex-col gap-4 text-center">
        <h2 class="text-xl font-semibold text-white">Connect</h2>
        <p class="text-slate-400 leading-relaxed max-w-2xl mx-auto">
          For booking, collaboration inquiries, or more information about {artist.name},
          please reach out through the label.
        </p>
        <div class="pt-2">
          <span class="text-xs text-slate-500 uppercase tracking-[0.2em]">
            Contact via Tender Circuits
          </span>
        </div>
      </div>
    </section>
  </section>
</LabelLayout>
