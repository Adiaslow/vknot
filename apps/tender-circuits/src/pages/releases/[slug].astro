---
import LabelLayout from "../../layouts/LabelLayout.astro";
import Tracklist from "../../components/Tracklist.astro";
import { fetchSpotifyAlbum, transformSpotifyAlbumToRelease } from "../../utils/spotify";
import {
  releases,
  getReleaseStatus,
  getVisibleReleasesByArtist,
  type Release,
} from "../../data/releases";

export function getStaticPaths() {
  // Generate a page for every release (including hidden ones, which redirect).
  return releases.map((release) => ({
    params: { slug: release.slug },
    props: { release },
  }));
}

interface Props {
  release: Release;
}

const { release } = Astro.props;

// Hidden release: keep the route in the codebase but redirect away.
if (release.hidden) {
  return Astro.redirect("/tender_circuits/releases");
}

const status = getReleaseStatus(release);

// Fetch Spotify data only when an album id is present.
let spotifyData: ReturnType<typeof transformSpotifyAlbumToRelease> | null = null;
if (release.spotifyAlbumId) {
  const spotifyAlbum = await fetchSpotifyAlbum(release.spotifyAlbumId);
  if (spotifyAlbum) {
    spotifyData = transformSpotifyAlbumToRelease(spotifyAlbum);
  } else if (status === "published") {
    // A published release must resolve on Spotify.
    throw new Error(
      `Failed to fetch Spotify album data for ${release.catalogNumber} (${release.spotifyAlbumId}). Check your Spotify credentials in .env file.`,
    );
  }
}

const title = spotifyData?.title || release.title || release.slug;
const artist = spotifyData?.artist || release.artistName;
const artwork = spotifyData?.artwork ?? null;
const tracklist = spotifyData?.tracklist ?? [];
const duration = spotifyData?.duration ?? null;
const releaseDate = spotifyData?.releaseDate ?? null;
const year = spotifyData?.year ?? release.year ?? null;
const spotifyUrl = spotifyData?.spotifyUrl ?? null;

const statusLabel = status === "preRelease" ? "Pre-Release" : "Coming Soon";

// Related releases by the same artist (visible, excluding this one).
const relatedReleases = getVisibleReleasesByArtist(release.artistSlug).filter(
  (r) => r.slug !== release.slug,
);
---

<LabelLayout
  title={`${title} - ${artist}`}
  description={`${title} by ${artist} on Tender Circuits.${release.description ? " " + release.description.substring(0, 150) + "..." : ""}`}
>
  <section class="flex flex-col gap-16">
    {/* Navigation and Release Header */}
    <div class="card rounded-2xl p-8">
      <div class="flex flex-col gap-6">
        <div class="flex items-center gap-2 text-sm text-slate-400">
          <a
            href="/tender_circuits/releases"
            class="hover:text-slate-300 transition-colors">Releases</a
          >
          <span>/</span>
          <span>{title}</span>
        </div>

        <div class="flex items-center gap-3 flex-wrap">
          <span
            class="text-xs uppercase tracking-[0.3em] text-emerald-300 bg-emerald-900/30 px-3 py-1 rounded-full"
          >
            {release.catalogNumber}
          </span>
          {status === "published" && releaseDate && (
            <span class="text-xs text-slate-400 font-mono">{releaseDate}</span>
          )}
          {status === "preRelease" && (
            <span
              class="text-xs uppercase tracking-[0.3em] text-violet-300 bg-violet-900/30 px-3 py-1 rounded-full"
            >
              Pre-Release
            </span>
          )}
          {status === "comingSoon" && (
            <span
              class="text-xs uppercase tracking-[0.3em] text-amber-300 bg-amber-900/30 px-3 py-1 rounded-full"
            >
              Coming Soon
            </span>
          )}
        </div>

        <div class="flex flex-col gap-3">
          <h1 class="text-4xl font-bold text-white tracking-tight">
            {title}
          </h1>
          <div class="flex items-center gap-2">
            <span class="text-xl text-slate-300">by</span>
            <a
              href={`/tender_circuits/artists/${release.artistSlug}`}
              class="text-xl text-emerald-300 hover:text-emerald-200 transition-colors font-medium"
            >
              {artist}
            </a>
          </div>
        </div>

        {release.description && (
          <p class="text-lg text-slate-300 leading-relaxed max-w-4xl">
            {release.description}
          </p>
        )}

        {/* Genres and Tags */}
        {(release.genres.length > 0 || release.subgenres.length > 0 || release.style) && (
          <div class="flex flex-wrap gap-2">
            {release.genres.map((genre) => (
              <span class="text-xs px-3 py-1 rounded-full bg-slate-800 text-slate-300 border border-slate-700">
                {genre}
              </span>
            ))}
            {release.subgenres.map((subgenre) => (
              <span class="text-xs px-3 py-1 rounded-full bg-fuchsia-900/30 text-fuchsia-300 border border-fuchsia-800/50">
                {subgenre}
              </span>
            ))}
            {release.style && (
              <span class="text-xs px-3 py-1 rounded-full bg-slate-700/50 text-slate-400 border border-slate-600/50">
                {release.style}
              </span>
            )}
          </div>
        )}
      </div>
    </div>

    <div class="flex flex-col gap-12">

      {/* Album Artwork — prefer custom vinyl artwork, fall back to Spotify */}
      {release.vinylArtwork ? (
        <div class="card vinyl-card w-full">
          <img
            src={release.vinylArtwork}
            alt={`${title} album artwork`}
            class="vinyl-artwork w-full h-auto"
          />
        </div>
      ) : artwork && (
        <div class="card rounded-2xl overflow-hidden max-w-2xl">
          <img
            src={artwork}
            alt={`${title} album artwork`}
            class="velvet-artwork-frame w-full h-auto"
          />
        </div>
      )}

      {/* Release Info */}
      <div class="grid gap-6 md:grid-cols-2">
        <div class="card rounded-2xl p-6">
          <div class="flex flex-col gap-4">
            <h3
              class="text-sm font-medium text-slate-400 uppercase tracking-[0.2em]"
            >
              Release Information
            </h3>
            <div class="grid gap-3">
              {duration && (
                <div class="flex justify-between">
                  <span class="text-slate-500">Duration:</span>
                  <span class="text-slate-300 font-mono">{duration}</span>
                </div>
              )}
              <div class="flex justify-between">
                <span class="text-slate-500">Format:</span>
                <span class="text-slate-300">Digital</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-500">Catalog:</span>
                <span class="text-slate-300 font-mono">{release.catalogNumber}</span>
              </div>
              {status === "published" ? (
                year && (
                  <div class="flex justify-between">
                    <span class="text-slate-500">Year:</span>
                    <span class="text-slate-300">{year}</span>
                  </div>
                )
              ) : (
                <div class="flex justify-between">
                  <span class="text-slate-500">Status:</span>
                  <span class={status === "preRelease" ? "text-violet-300" : "text-amber-300"}>
                    {statusLabel}
                  </span>
                </div>
              )}
            </div>
          </div>
        </div>

        <div class="card rounded-2xl p-6">
          <div class="flex flex-col gap-4">
            <h3
              class="text-sm font-medium text-slate-400 uppercase tracking-[0.2em]"
            >
              {status === "published" ? "Listen" : "Availability"}
            </h3>
            <div class="flex flex-col gap-3 items-center justify-center py-4">
              {spotifyUrl ? (
                <a
                  href={spotifyUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full rounded-lg bg-emerald-900/30 border border-emerald-800/50 py-3 px-4 text-emerald-300 hover:bg-emerald-900/50 hover:text-emerald-200 transition-all duration-200 font-medium text-center flex items-center justify-center gap-2"
                >
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                  </svg>
                  Listen on Spotify
                </a>
              ) : (
                <>
                  <span class={`text-sm font-medium ${status === "preRelease" ? "text-violet-300" : "text-amber-300"}`}>
                    {statusLabel}
                  </span>
                  <p class="text-slate-400 text-sm text-center">
                    This release will be available on all major streaming platforms.
                  </p>
                </>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Track Listing */}
    {tracklist.length > 0 && (
      <section class="card rounded-2xl p-8">
        <Tracklist tracks={tracklist} totalDuration={duration} />
      </section>
    )}

    {/* Credits */}
    {Object.keys(release.credits).length > 0 && (
      <section class="card rounded-2xl p-8">
        <div class="flex flex-col gap-6">
          <h2 class="text-xl font-semibold text-white">Credits</h2>

          <div class="grid gap-3">
            {Object.entries(release.credits).map(([role, credit]) => (
              <div class="flex flex-col sm:flex-row sm:justify-between gap-1">
                <span class="text-slate-500 text-sm">{role}:</span>
                <span class="text-slate-300">{credit}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Production Notes */}
    {release.notes && (
      <section class="card rounded-2xl p-8">
        <div class="flex flex-col gap-4">
          <h2 class="text-xl font-semibold text-white">Production Notes</h2>
          <p class="text-slate-400 leading-relaxed">
            {release.notes}
          </p>
        </div>
      </section>
    )}

    {/* Related */}
    <section class="flex flex-col gap-10">
      <div class="card rounded-2xl p-6">
        <h2 class="text-xl font-semibold text-white">More from {artist}</h2>
      </div>

      <div class="card rounded-2xl p-8">
        <div class="flex flex-col gap-4 text-center">
          {relatedReleases.length > 0 && (
            <>
              <p class="text-slate-400">Also on Tender Circuits:</p>
              <div class="flex items-center gap-4 justify-center flex-wrap pt-2">
                {relatedReleases.map((r) => (
                  <a
                    class="inline-flex items-center gap-2 text-sm font-medium text-emerald-300 hover:text-emerald-200 transition-colors"
                    href={`/tender_circuits/releases/${r.slug}`}
                  >
                    <span>{r.title || r.slug}</span>
                    {getReleaseStatus(r) === "comingSoon" && (
                      <span class="text-xs uppercase tracking-[0.3em] text-amber-300 bg-amber-900/30 px-2 py-0.5 rounded-full">
                        Coming Soon
                      </span>
                    )}
                    {getReleaseStatus(r) === "preRelease" && (
                      <span class="text-xs uppercase tracking-[0.3em] text-violet-300 bg-violet-900/30 px-2 py-0.5 rounded-full">
                        Pre-Release
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </>
          )}
          <div class="flex items-center gap-4 justify-center pt-2">
            <a
              class="inline-flex items-center gap-2 text-sm font-medium text-emerald-300 hover:text-emerald-200 transition-colors"
              href={`/tender_circuits/artists/${release.artistSlug}`}
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                ></path>
              </svg>
              <span>View Artist Profile</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </section>
</LabelLayout>
