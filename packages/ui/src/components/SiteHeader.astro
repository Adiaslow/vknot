---
/**
 * SiteHeader — the themed top-of-page navigation used by every
 * adam-murray subsite. Token-driven; flips with the Paper / Ink
 * theme automatically.
 *
 * Each subsite passes its own brand name, base URL, and primary
 * links. The component renders the NodeRing brand mark and the
 * Paper/Ink theme toggle on every page.
 *
 *   <SiteHeader
 *     siteName="Adam Murray - Research"
 *     baseUrl="/adam-murray/research"
 *     links={[
 *       { href: "/adam-murray/research", label: "Home" },
 *       { href: "/adam-murray/research/publications", label: "Publications" },
 *     ]}
 *   />
 */
import NodeRing from "./NodeRing.astro";
import ThemeToggle from "./ThemeToggle.astro";

export interface SiteHeaderLink {
  href: string;
  label: string;
}

export interface Props {
  readonly siteName: string;
  readonly baseUrl: string;
  readonly links: ReadonlyArray<SiteHeaderLink>;
}

const { siteName, baseUrl, links } = Astro.props;

// current path for active-link state (tolerant of trailing slash)
const here = Astro.url.pathname.replace(/\/$/, "");
const isActive = (href: string) => here === href.replace(/\/$/, "");
---

<header class="site-header">
  <div class="inner">
    <a class="brand" href={baseUrl} aria-label={siteName}>
      <NodeRing nodes={7} chords={2} size={28} title={siteName} />
      <span class="brand-name">{siteName}</span>
    </a>
    <nav class="links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class:list={["link", { "is-active": isActive(l.href) }]}>
          {l.label}
        </a>
      ))}
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in oklch, var(--paper) 86%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
  }
  .inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink);
  }
  .brand-name {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .links {
    margin-left: auto;
    display: flex;
    gap: 0.25rem;
  }
  .link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--muted);
    padding: 0.45rem 0.75rem;
    transition: color .2s;
  }
  .link:hover { color: var(--ink); }
  .link.is-active {
    color: var(--ink);
    box-shadow: inset 0 -2px 0 var(--accent);
  }

  @media (max-width: 640px) {
    .brand-name { display: none; }
    .inner { gap: 0.75rem; padding: 0.75rem 1rem; }
  }
</style>
